<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.Cocoa.XIB" version="3.0" toolsVersion="21701" targetRuntime="MacOSX.Cocoa" propertyAccessControl="none" useAutolayout="YES" customObjectInstantitationMethod="direct">
    <dependencies>
        <deployment identifier="macosx"/>
        <plugIn identifier="com.apple.InterfaceBuilder.CocoaPlugin" version="21701"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <customObject id="-2" userLabel="File's Owner" customClass="PlaylistViewController" customModule="Audion" customModuleProvider="target">
            <connections>
                <outlet property="addFilesButton" destination="add-files-btn" id="add-files-outlet"/>
                <outlet property="clearButton" destination="clear-btn" id="clear-outlet"/>
                <outlet property="infoButton" destination="info-btn" id="info-outlet"/>
                <outlet property="nextButton" destination="next-btn" id="next-outlet"/>
                <outlet property="playPauseButton" destination="playpause-btn" id="playpause-outlet"/>
                <outlet property="positionSlider" destination="position-slider" id="position-outlet"/>
                <outlet property="previousButton" destination="previous-btn" id="previous-outlet"/>
                <outlet property="shuffleButton" destination="shuffle-btn" id="shuffle-outlet"/>
                <outlet property="tableView" destination="playlist-table" id="table-outlet"/>
                <outlet property="view" destination="playlist-view" id="view-outlet"/>
            </connections>
        </customObject>
        <customObject id="-1" userLabel="First Responder" customClass="FirstResponder"/>
        <customObject id="-3" userLabel="Application" customClass="NSObject"/>
        <customView id="playlist-view">
            <rect key="frame" x="0.0" y="0.0" width="600" height="500"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMinY="YES"/>
            <subviews>
                <button verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="previous-btn" toolTip="Previous Track (⌘←)">
                    <rect key="frame" x="8" y="476" width="32" height="20"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="32" id="previous-width"/>
                    </constraints>
                    <buttonCell key="cell" type="push" title="⏮" bezelStyle="rounded" alignment="center" controlSize="small" borderStyle="border" imageScaling="proportionallyDown" inset="2" id="previous-cell">
                        <behavior key="behavior" pushIn="YES" lightByBackground="YES" lightByGray="YES"/>
                        <font key="font" metaFont="smallSystem"/>
                    </buttonCell>
                    <connections>
                        <action selector="previousTrack:" target="-2" id="previous-action"/>
                    </connections>
                </button>
                <button verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="playpause-btn" toolTip="Play/Pause (Space)">
                    <rect key="frame" x="48" y="476" width="32" height="20"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="32" id="playpause-width"/>
                    </constraints>
                    <buttonCell key="cell" type="push" title="⏯" bezelStyle="rounded" alignment="center" controlSize="small" borderStyle="border" imageScaling="proportionallyDown" inset="2" id="playpause-cell">
                        <behavior key="behavior" pushIn="YES" lightByBackground="YES" lightByGray="YES"/>
                        <font key="font" metaFont="smallSystem"/>
                    </buttonCell>
                    <connections>
                        <action selector="playPause:" target="-2" id="playpause-action"/>
                    </connections>
                </button>
                <button verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="next-btn" toolTip="Next Track (⌘→)">
                    <rect key="frame" x="88" y="476" width="32" height="20"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="32" id="next-width"/>
                    </constraints>
                    <buttonCell key="cell" type="push" title="⏭" bezelStyle="rounded" alignment="center" controlSize="small" borderStyle="border" imageScaling="proportionallyDown" inset="2" id="next-cell">
                        <behavior key="behavior" pushIn="YES" lightByBackground="YES" lightByGray="YES"/>
                        <font key="font" metaFont="smallSystem"/>
                    </buttonCell>
                    <connections>
                        <action selector="nextTrack:" target="-2" id="next-action"/>
                    </connections>
                </button>
                <slider verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="position-slider">
                    <rect key="frame" x="128" y="476" width="464" height="20"/>
                    <sliderCell key="cell" controlSize="small" continuous="YES" state="on" alignment="left" minValue="0.0" maxValue="100" doubleValue="0.0" tickMarkPosition="none" sliderType="linear" id="position-slider-cell"/>
                </slider>
                <scrollView borderType="none" autohidesScrollers="YES" horizontalLineScroll="20" horizontalPageScroll="10" verticalLineScroll="20" verticalPageScroll="10" usesPredominantAxisScrolling="NO" translatesAutoresizingMaskIntoConstraints="NO" id="scroll-view">
                    <rect key="frame" x="0.0" y="44" width="600" height="426"/>
                    <clipView key="contentView" drawsBackground="NO" id="clip-view">
                        <rect key="frame" x="0.0" y="0.0" width="400" height="456"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <subviews>
                            <tableView verticalHuggingPriority="750" allowsExpansionToolTips="YES" columnAutoresizingStyle="lastColumnOnly" columnReordering="NO" columnResizing="YES" multipleSelection="YES" autosaveColumns="NO" rowHeight="32" headerView="header-view" id="playlist-table">
                                <rect key="frame" x="0.0" y="0.0" width="600" height="456"/>
                                <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                                <size key="intercellSpacing" width="3" height="2"/>
                                <color key="backgroundColor" name="controlBackgroundColor" catalog="System" colorSpace="catalog"/>
                                <color key="gridColor" name="gridColor" catalog="System" colorSpace="catalog"/>
                                <tableColumns>
                                    <tableColumn identifier="ArtColumn" width="40" minWidth="40" maxWidth="40" id="art-column">
                                        <tableHeaderCell key="headerCell" lineBreakMode="truncatingTail" borderStyle="border" alignment="left" title="">
                                            <color key="textColor" name="headerTextColor" catalog="System" colorSpace="catalog"/>
                                            <color key="backgroundColor" name="headerColor" catalog="System" colorSpace="catalog"/>
                                        </tableHeaderCell>
                                        <imageCell key="dataCell" refusesFirstResponder="YES" alignment="left" imageScaling="proportionallyUpOrDown" id="art-cell"/>
                                        <tableColumnResizingMask key="resizingMask" userResizable="NO"/>
                                    </tableColumn>
                                    <tableColumn identifier="TrackColumn" width="200" minWidth="80" maxWidth="1000" id="track-column">
                                        <tableHeaderCell key="headerCell" lineBreakMode="truncatingTail" borderStyle="border" alignment="left" title="Track">
                                            <color key="textColor" name="headerTextColor" catalog="System" colorSpace="catalog"/>
                                            <color key="backgroundColor" name="headerColor" catalog="System" colorSpace="catalog"/>
                                        </tableHeaderCell>
                                        <textFieldCell key="dataCell" lineBreakMode="truncatingTail" selectable="YES" editable="YES" alignment="left" title="Text Cell" id="track-cell">
                                            <font key="font" metaFont="system"/>
                                            <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                                            <color key="backgroundColor" name="controlBackgroundColor" catalog="System" colorSpace="catalog"/>
                                        </textFieldCell>
                                        <tableColumnResizingMask key="resizingMask" resizeWithTable="YES" userResizable="YES"/>
                                    </tableColumn>
                                    <tableColumn identifier="ArtistColumn" width="100" minWidth="60" maxWidth="1000" id="artist-column">
                                        <tableHeaderCell key="headerCell" lineBreakMode="truncatingTail" borderStyle="border" alignment="left" title="Artist">
                                            <color key="textColor" name="headerTextColor" catalog="System" colorSpace="catalog"/>
                                            <color key="backgroundColor" name="headerColor" catalog="System" colorSpace="catalog"/>
                                        </tableHeaderCell>
                                        <textFieldCell key="dataCell" lineBreakMode="truncatingTail" selectable="YES" editable="YES" alignment="left" title="Text Cell" id="artist-cell">
                                            <font key="font" metaFont="system"/>
                                            <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                                            <color key="backgroundColor" name="controlBackgroundColor" catalog="System" colorSpace="catalog"/>
                                        </textFieldCell>
                                        <tableColumnResizingMask key="resizingMask" resizeWithTable="YES" userResizable="YES"/>
                                    </tableColumn>
                                    <tableColumn identifier="AlbumColumn" width="100" minWidth="60" maxWidth="1000" id="album-column">
                                        <tableHeaderCell key="headerCell" lineBreakMode="truncatingTail" borderStyle="border" alignment="left" title="Album">
                                            <color key="textColor" name="headerTextColor" catalog="System" colorSpace="catalog"/>
                                            <color key="backgroundColor" name="headerColor" catalog="System" colorSpace="catalog"/>
                                        </tableHeaderCell>
                                        <textFieldCell key="dataCell" lineBreakMode="truncatingTail" selectable="YES" editable="YES" alignment="left" title="Text Cell" id="album-cell">
                                            <font key="font" metaFont="system"/>
                                            <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                                            <color key="backgroundColor" name="controlBackgroundColor" catalog="System" colorSpace="catalog"/>
                                        </textFieldCell>
                                        <tableColumnResizingMask key="resizingMask" resizeWithTable="YES" userResizable="YES"/>
                                    </tableColumn>
                                    <tableColumn identifier="DurationColumn" width="50" minWidth="40" maxWidth="1000" id="duration-column">
                                        <tableHeaderCell key="headerCell" lineBreakMode="truncatingTail" borderStyle="border" alignment="right" title="Time">
                                            <color key="textColor" name="headerTextColor" catalog="System" colorSpace="catalog"/>
                                            <color key="backgroundColor" name="headerColor" catalog="System" colorSpace="catalog"/>
                                        </tableHeaderCell>
                                        <textFieldCell key="dataCell" lineBreakMode="truncatingTail" selectable="YES" editable="YES" alignment="right" title="Text Cell" id="duration-cell">
                                            <font key="font" metaFont="system"/>
                                            <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                                            <color key="backgroundColor" name="controlBackgroundColor" catalog="System" colorSpace="catalog"/>
                                        </textFieldCell>
                                        <tableColumnResizingMask key="resizingMask" resizeWithTable="YES" userResizable="YES"/>
                                    </tableColumn>
                                </tableColumns>
                            </tableView>
                        </subviews>
                    </clipView>
                    <scroller key="horizontalScroller" hidden="YES" wantsLayer="YES" verticalHuggingPriority="750" horizontal="YES" id="h-scroller">
                        <rect key="frame" x="-100" y="-100" width="87" height="18"/>
                        <autoresizingMask key="autoresizingMask"/>
                    </scroller>
                    <scroller key="verticalScroller" wantsLayer="YES" verticalHuggingPriority="750" horizontal="NO" id="v-scroller">
                        <rect key="frame" x="384" y="0.0" width="16" height="456"/>
                        <autoresizingMask key="autoresizingMask"/>
                    </scroller>
                    <tableHeaderView key="headerView" id="header-view">
                        <rect key="frame" x="0.0" y="0.0" width="400" height="23"/>
                        <autoresizingMask key="autoresizingMask"/>
                    </tableHeaderView>
                </scrollView>
                <box boxType="separator" translatesAutoresizingMaskIntoConstraints="NO" id="separator">
                    <rect key="frame" x="0.0" y="42" width="400" height="2"/>
                </box>
                <button verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="add-files-btn" toolTip="Add Files (⌘⇧⌫)">
                    <rect key="frame" x="8" y="8" width="100" height="32"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="100" id="add-files-width"/>
                    </constraints>
                    <buttonCell key="cell" type="push" title="Add Files..." bezelStyle="rounded" alignment="center" borderStyle="border" imageScaling="proportionallyDown" inset="2" id="add-files-cell">
                        <behavior key="behavior" pushIn="YES" lightByBackground="YES" lightByGray="YES"/>
                        <font key="font" metaFont="system"/>
                    </buttonCell>
                    <connections>
                        <action selector="addFiles:" target="-2" id="add-files-action"/>
                    </connections>
                </button>
                <button verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="shuffle-btn" toolTip="Toggle Shuffle (⌘U)">
                    <rect key="frame" x="116" y="8" width="80" height="32"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="80" id="shuffle-width"/>
                    </constraints>
                    <buttonCell key="cell" type="push" title="Shuffle" bezelStyle="rounded" alignment="center" borderStyle="border" imageScaling="proportionallyDown" inset="2" id="shuffle-cell">
                        <behavior key="behavior" pushIn="YES" lightByBackground="YES" lightByGray="YES"/>
                        <font key="font" metaFont="system"/>
                    </buttonCell>
                    <connections>
                        <action selector="toggleShuffle:" target="-2" id="shuffle-action"/>
                    </connections>
                </button>
                <button verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="save-btn" toolTip="Save Playlist (⌘S)">
                    <rect key="frame" x="204" y="8" width="60" height="32"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="60" id="save-width"/>
                    </constraints>
                    <buttonCell key="cell" type="push" title="Save" bezelStyle="rounded" alignment="center" borderStyle="border" imageScaling="proportionallyDown" inset="2" id="save-cell">
                        <behavior key="behavior" pushIn="YES" lightByBackground="YES" lightByGray="YES"/>
                        <font key="font" metaFont="system"/>
                    </buttonCell>
                    <connections>
                        <action selector="savePlaylist:" target="-2" id="save-action"/>
                    </connections>
                </button>
                <button verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="load-btn" toolTip="Load Playlist (⌘L)">
                    <rect key="frame" x="272" y="8" width="60" height="32"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="60" id="load-width"/>
                    </constraints>
                    <buttonCell key="cell" type="push" title="Load" bezelStyle="rounded" alignment="center" borderStyle="border" imageScaling="proportionallyDown" inset="2" id="load-cell">
                        <behavior key="behavior" pushIn="YES" lightByBackground="YES" lightByGray="YES"/>
                        <font key="font" metaFont="system"/>
                    </buttonCell>
                    <connections>
                        <action selector="loadPlaylist:" target="-2" id="load-action"/>
                    </connections>
                </button>
                <button verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="clear-btn" toolTip="Clear Playlist (⌘K)">
                    <rect key="frame" x="272" y="8" width="52" height="32"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="52" id="clear-width"/>
                    </constraints>
                    <buttonCell key="cell" type="push" title="Clear" bezelStyle="rounded" alignment="center" borderStyle="border" imageScaling="proportionallyDown" inset="2" id="clear-cell">
                        <behavior key="behavior" pushIn="YES" lightByBackground="YES" lightByGray="YES"/>
                        <font key="font" metaFont="system"/>
                    </buttonCell>
                    <connections>
                        <action selector="clearPlaylist:" target="-2" id="clear-action"/>
                    </connections>
                </button>
                <button verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="info-btn" toolTip="Show Track Info (⌘I)">
                    <rect key="frame" x="340" y="8" width="52" height="32"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="52" id="info-width"/>
                    </constraints>
                    <buttonCell key="cell" type="push" title="Info" bezelStyle="rounded" alignment="center" borderStyle="border" imageScaling="proportionallyDown" inset="2" id="info-cell">
                        <behavior key="behavior" pushIn="YES" lightByBackground="YES" lightByGray="YES"/>
                        <font key="font" metaFont="system"/>
                    </buttonCell>
                    <connections>
                        <action selector="showInfoDrawer" target="-2" id="info-action"/>
                    </connections>
                </button>
            </subviews>
            <constraints>
                <constraint firstItem="previous-btn" firstAttribute="top" secondItem="playlist-view" secondAttribute="top" constant="6" id="previous-top"/>
                <constraint firstItem="previous-btn" firstAttribute="leading" secondItem="playlist-view" secondAttribute="leading" constant="10" id="previous-leading"/>
                <constraint firstItem="playpause-btn" firstAttribute="leading" secondItem="previous-btn" secondAttribute="trailing" constant="8" id="playpause-leading"/>
                <constraint firstItem="playpause-btn" firstAttribute="centerY" secondItem="previous-btn" secondAttribute="centerY" id="playpause-center"/>
                <constraint firstItem="next-btn" firstAttribute="leading" secondItem="playpause-btn" secondAttribute="trailing" constant="8" id="next-leading"/>
                <constraint firstItem="next-btn" firstAttribute="centerY" secondItem="previous-btn" secondAttribute="centerY" id="next-center"/>
                <constraint firstItem="position-slider" firstAttribute="leading" secondItem="next-btn" secondAttribute="trailing" constant="8" id="slider-leading"/>
                <constraint firstItem="position-slider" firstAttribute="centerY" secondItem="previous-btn" secondAttribute="centerY" id="slider-center"/>
                <constraint firstAttribute="trailing" secondItem="position-slider" secondAttribute="trailing" constant="10" id="slider-trailing"/>
                <constraint firstItem="scroll-view" firstAttribute="top" secondItem="position-slider" secondAttribute="bottom" constant="6" id="scroll-top"/>
                <constraint firstItem="scroll-view" firstAttribute="leading" secondItem="playlist-view" secondAttribute="leading" id="scroll-leading"/>
                <constraint firstAttribute="trailing" secondItem="scroll-view" secondAttribute="trailing" id="scroll-trailing"/>
                <constraint firstItem="separator" firstAttribute="top" secondItem="scroll-view" secondAttribute="bottom" id="separator-top"/>
                <constraint firstItem="separator" firstAttribute="leading" secondItem="playlist-view" secondAttribute="leading" id="separator-leading"/>
                <constraint firstAttribute="trailing" secondItem="separator" secondAttribute="trailing" id="separator-trailing"/>
                <constraint firstItem="add-files-btn" firstAttribute="leading" secondItem="playlist-view" secondAttribute="leading" constant="8" id="add-leading"/>
                <constraint firstItem="add-files-btn" firstAttribute="top" secondItem="separator" secondAttribute="bottom" constant="8" id="add-top"/>
                <constraint firstAttribute="bottom" secondItem="add-files-btn" secondAttribute="bottom" constant="8" id="add-bottom"/>
                <constraint firstItem="shuffle-btn" firstAttribute="leading" secondItem="add-files-btn" secondAttribute="trailing" constant="8" id="shuffle-leading"/>
                <constraint firstItem="shuffle-btn" firstAttribute="centerY" secondItem="add-files-btn" secondAttribute="centerY" id="shuffle-center"/>
                <constraint firstItem="save-btn" firstAttribute="leading" secondItem="shuffle-btn" secondAttribute="trailing" constant="8" id="save-leading"/>
                <constraint firstItem="save-btn" firstAttribute="centerY" secondItem="add-files-btn" secondAttribute="centerY" id="save-center"/>
                <constraint firstItem="load-btn" firstAttribute="leading" secondItem="save-btn" secondAttribute="trailing" constant="8" id="load-leading"/>
                <constraint firstItem="load-btn" firstAttribute="centerY" secondItem="add-files-btn" secondAttribute="centerY" id="load-center"/>
                <constraint firstItem="clear-btn" firstAttribute="leading" secondItem="load-btn" secondAttribute="trailing" constant="8" id="clear-leading"/>
                <constraint firstItem="clear-btn" firstAttribute="centerY" secondItem="add-files-btn" secondAttribute="centerY" id="clear-center"/>
                <constraint firstItem="info-btn" firstAttribute="leading" secondItem="clear-btn" secondAttribute="trailing" constant="8" id="info-leading"/>
                <constraint firstItem="info-btn" firstAttribute="centerY" secondItem="add-files-btn" secondAttribute="centerY" id="info-center"/>
                <constraint firstAttribute="trailing" relation="greaterThanOrEqual" secondItem="info-btn" secondAttribute="trailing" constant="8" id="info-min-trailing"/>
                <constraint firstAttribute="width" relation="greaterThanOrEqual" constant="460" id="min-width"/>
            </constraints>
        </customView>
    </objects>
</document>
